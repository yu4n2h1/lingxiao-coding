{
  "name": "lingxiao_cli",
  "version": "1.0.0",
  "description": "凌霄剑域 - 动态智能编排系统 (Node.js 版本)",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "build": "node scripts/build.mjs",
    "build:package": "node scripts/build.mjs --package",
    "build:web": "node scripts/build.mjs --web-only",
    "build:server": "node scripts/build.mjs --server-only",
    "desktop:dev": "npm run build && electron dist/desktop/main.js",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:msi": "npm run build && electron-builder --win msi --publish never --config.electronDist=node_modules/electron/dist",
    "desktop:dist": "npm run build && electron-builder",
    "package:portable": "node scripts/package-portable.mjs",
    "build:binary": "node scripts/build-binary.mjs",
    "fetch-models": "node scripts/fetch-models-snapshot.mjs",
    "bump": "node scripts/bump-version.mjs",
    "dev:test-llm-request": "tsx src/test-llm-request.ts",
    "eval:drift": "tsx src/eval/runDriftEval.ts",
    "eval:security": "node scripts/run-security-eval.mjs",
    "test:architecture": "tsx --test src/architecture_refactor_invariants.test.ts",
    "test:scripts": "node --test scripts/canonical-source-invariants.test.mjs",
    "test": "npm run test:scripts && npm run build && node scripts/run-tests.mjs",
    "test:ci": "npm run test:scripts && npm run build:server && node scripts/run-tests.mjs",
    "start": "node dist/cli.js",
    "cli": "node dist/cli.js",
    "setup": "node scripts/postinstall.mjs",
    "link:cli": "npm link",
    "prepack": "npm run build:package",
    "prepublishOnly": "npm run build:package"
  },
  "bin": {
    "lingxiao": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "!dist/test-llm-request.js",
    "!dist/test-llm-request.js.map",
    "!dist/test-llm-request.d.ts",
    "!dist/test-llm-request.d.ts.map",
    "skills/",
    "!skills/bundled/huashu-design/assets/",
    "tessdata/",
    "scripts/postinstall.mjs",
    "scripts/build.mjs",
    "tsconfig.package.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [],
  "author": "LingXiao",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.2.14",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^3.0.101",
    "@ai-sdk/anthropic": "^2.0.81",
    "@ai-sdk/google": "^2.0.74",
    "@ai-sdk/openai": "^2.0.106",
    "@anthropic-ai/sdk": "^0.82.0",
    "@ast-grep/lang-c": "^0.0.6",
    "@ast-grep/lang-cpp": "^0.0.6",
    "@ast-grep/lang-go": "^0.0.6",
    "@ast-grep/lang-java": "^0.0.7",
    "@ast-grep/lang-python": "^0.0.6",
    "@ast-grep/lang-ruby": "^0.0.7",
    "@ast-grep/lang-rust": "^0.0.7",
    "@ast-grep/napi": "^0.42.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.1",
    "@fastify/websocket": "^11.2.0",
    "@langfuse/client": "^5.5.3",
    "@langfuse/otel": "^5.5.3",
    "@langfuse/tracing": "^5.5.3",
    "@lydell/node-pty": "1.2.0-beta.10",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nodesecure/js-x-ray": "^11.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@slidev/cli": "^52.15.2",
    "@xterm/headless": "5.5.0",
    "acorn": "^8.16.0",
    "ai": "^5.0.198",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "fastify": "^5.8.4",
    "glob": "^13.0.6",
    "ink": "^6.8.0",
    "inquirer": "^13.3.2",
    "js-tiktoken": "^1.0.21",
    "jszip": "^3.10.1",
    "lowlight": "^3.3.0",
    "mammoth": "^1.12.0",
    "node-fetch": "^3.3.2",
    "openai": "^6.33.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "playwright": "^1.59.1",
    "pptxgenjs": "^4.0.1",
    "proxy-agent": "^8.0.1",
    "react": "^19.2.4",
    "react-virtuoso": "^4.18.7",
    "sharp": "^0.34.5",
    "simple-git": "^3.36.0",
    "skia-canvas": "^3.0.8",
    "string-width": "^8.2.0",
    "strip-ansi": "^7.2.0",
    "tesseract.js": "^7.0.0",
    "undici": "^8.0.2",
    "unzipper": "^0.12.3",
    "wrap-ansi": "^10.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@lydell/node-pty-darwin-arm64": "1.2.0-beta.10",
    "@lydell/node-pty-darwin-x64": "1.2.0-beta.10",
    "@lydell/node-pty-linux-arm64": "1.2.0-beta.10",
    "@lydell/node-pty-linux-x64": "1.2.0-beta.10",
    "@lydell/node-pty-win32-arm64": "1.2.0-beta.10",
    "@lydell/node-pty-win32-x64": "1.2.0-beta.10"
  },
  "overrides": {
    "exceljs": {
      "uuid": "^11.1.1"
    },
    "esbuild": "0.28.1",
    "traverse": "0.3.9",
    "@jridgewell/trace-mapping": "^0.3.25"
  },
  "build": {
    "appId": "cn.lingxiao.desktop",
    "productName": "LingXiao",
    "directories": {
      "output": "release/desktop"
    },
    "extraMetadata": {
      "main": "dist/desktop/main.js"
    },
    "msiProjectCreated": "scripts/patch-msi-project-codepage.cjs",
    "files": [
      "dist/**/*",
      "package.json",
      "LICENSE"
    ],
    "extraResources": [
      {
        "from": "skills",
        "to": "skills",
        "filter": [
          "**/*",
          "!bundled/huashu-design/assets/**/*"
        ]
      }
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "icon": "build-resources/icon.ico",
      "target": [
        "msi",
        "nsis",
        "portable"
      ]
    },
    "msi": {
      "oneClick": false,
      "runAfterFinish": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "additionalLightArgs": [
        "-cultures:zh-cn"
      ],
      "shortcutName": "凌霄",
      "menuCategory": "凌霄"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  }
}
